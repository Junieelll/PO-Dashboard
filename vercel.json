{
  "version": 2,
  "rewrites": [
    { "source": "/auth/(.*)", "destination": "/api/index.js" },
    { "source": "/sheets/(.*)", "destination": "/api/index.js" },
    { "source": "/data/(.*)", "destination": "/api/index.js" },
    { "source": "/email/(.*)", "destination": "/api/index.js" },
    { "source": "/share/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
